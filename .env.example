# OpenRoleKB — environment variables
# Copy to .env.local for dev, set the corresponding production values in
# your hosting provider (Vercel, Fly, Railway, etc.). NEVER commit a real .env.

# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection. Neon / Supabase / RDS / local — any Postgres ≥ 15.
DATABASE_URL=postgresql://user:password@host/openrolekb?sslmode=require
# Same DB but pointing at the unpooled connection (used by Prisma Migrate).
# For Neon, this is the direct (non-pooler) URL. For local Postgres, set equal to DATABASE_URL.
DIRECT_URL=postgresql://user:password@host/openrolekb?sslmode=require

# Exa API key — https://exa.ai
EXA_API_KEY=

# DeepSeek API key — https://platform.deepseek.com/
# Drop-in replaceable with any OpenAI-compatible provider; edit src/lib/llm.ts.
DEEPSEEK_API_KEY=

# ── Auth (NextAuth / Auth.js v5) ────────────────────────────────────────────

# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the deployed app (e.g. https://openrolekb.app).
# In dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# Magic-link email transport — https://resend.com
RESEND_API_KEY=
RESEND_FROM=hello@openrolekb.app

# ── Public site config ──────────────────────────────────────────────────────

# Used for absolute URLs in metadata (OG cards, sitemaps).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Rate limiting (recommended for production) ──────────────────────────────

# Upstash Redis — https://upstash.com
# If unset, an in-memory rate limiter is used as a dev fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron auth ───────────────────────────────────────────────────────────────

# Shared secret expected as Authorization: Bearer ... on cron endpoints.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Observability (Sentry) ──────────────────────────────────────────────────

# Server-side DSN — error reporting from API routes + server components.
SENTRY_DSN=
# Client-side DSN — error reporting from the browser. Often the same project.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: a release identifier shown to clients (e.g. a build SHA).
NEXT_PUBLIC_SENTRY_RELEASE=
# Optional: only needed if you run `sentry-cli` to upload sourcemaps.
SENTRY_AUTH_TOKEN=

# ── Admin ───────────────────────────────────────────────────────────────────

# Email of the operator who can access /admin/* dashboards.
ADMIN_EMAIL=
